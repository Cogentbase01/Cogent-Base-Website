# ---------------------------------------------------------------------------
# Cogent Base — environment variables
# Copy to `.env.local` for local dev. Set the real values in Vercel project
# settings (never commit secrets). All are OPTIONAL for local dev: with none
# set, the demo form validates and "succeeds" while logging the request to the
# server console, and analytics/Turnstile are disabled.
# ---------------------------------------------------------------------------

# ---- Demo-request delivery (Resend) ----
RESEND_API_KEY=
# Where founder notifications are sent (comma-separated for multiple).
DEMO_NOTIFY_TO=founders@cogentbase.ai
# Verified Resend sender, e.g. "Cogent Base <demos@cogentbase.ai>".
DEMO_NOTIFY_FROM=Cogent Base <demos@cogentbase.ai>
# Optional: also POST each request to a CRM/webhook (Zapier, HubSpot, etc.).
DEMO_WEBHOOK_URL=

# ---- Spam protection (Cloudflare Turnstile) ----
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Cookieless analytics (Plausible / Fathom) ----
# Leave domain unset to disable analytics entirely (dev/preview).
NEXT_PUBLIC_ANALYTICS_DOMAIN=cogentbase.ai
# Optional override of the analytics script URL (defaults to Plausible).
NEXT_PUBLIC_ANALYTICS_SRC=https://plausible.io/js/script.js
